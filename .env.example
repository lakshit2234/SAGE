# ---- ChromaDB ----
CHROMA_PATH=./data/chroma

# ---- GitHub (fill in step 5) ----
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
