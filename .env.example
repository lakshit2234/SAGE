# ---- App ----
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ---- Postgres ----
POSTGRES_USER=sage
POSTGRES_PASSWORD=sage_dev_pw
POSTGRES_DB=sage
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Ollama ----
OLLAMA_BASE_URL=http://localhost:11434
